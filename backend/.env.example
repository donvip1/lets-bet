# Server
PORT=5001
NODE_ENV=production

# Database
# Preferred for Railway PostgreSQL. Paste Railway's PostgreSQL connection string here.
DATABASE_URL=postgresql://postgres:your-railway-password@your-railway-host.railway.internal:5432/railway

# Optional fallback if you do not use DATABASE_URL.
DB_HOST=your-railway-db-host.railway.internal
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-railway-db-password
DB_NAME=lets_bet
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Flutterwave (MOCK mode by default)
FLUTTERWAVE_ENV=mock
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST_KEY

# AI Service
AI_SERVICE_URL=http://localhost:8000

# Frontend URL (for CORS and payment redirects)
FRONTEND_URL=https://lets-bet-seven.vercel.app
